{
  "name": "@dropsy-ui/storybook-addon-docs-stencil",
  "version": "10.0.0",
  "description": "Converts stencil.js JsonDoc to storybook ArgTypes",
  "main": "dist/index.js",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./preview": {
      "types": "./dist/preview.d.ts",
      "default": "./dist/preview.js"
    },
    "./preset": "./dist/preset.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "start": "tsup --watch",
    "build": "npm run lint && tsup",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish",
    "format": "npm run prettier:fix && npm run lint:fix",
    "lint": "eslint . --report-unused-disable-directives",
    "lint:fix": "npm run lint -- --fix",
    "prettier": "prettier ./src --no-error-on-unmatched-pattern --check",
    "prettier:fix": "npm run prettier -- --write",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dropsy-ui/storybook-addon-docs-stencil.git"
  },
  "bugs": {
    "url": "https://github.com/dropsy-ui/storybook-addon-docs-stencil/issues"
  },
  "homepage": "https://github.com/dropsy-ui/storybook-addon-docs-stencil#readme",
  "author": "Andrew St. Jean <andrew@dropsy-ui.com>",
  "contributors": [
    "life4aiur"
  ],
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/eslint__js": "^8.42.3",
    "@types/node": "^25.5.0",
    "eslint": "^9.18.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "storybook": "^10.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1",
    "vite": "^6.0.7"
  },
  "peerDependencies": {
    "storybook": "^10.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*",
    "*.js",
    "*.d.ts"
  ],
  "bundler": {
    "exportEntries": [],
    "managerEntries": [],
    "previewEntries": [
      "src/index.ts",
      "src/preview.ts"
    ],
    "nodeEntries": [
      "src/preset.ts"
    ]
  },
  "storybook": {
    "displayName": "Stencil docs and controls",
    "supportedFrameworks": [
      "web-components",
      "html"
    ],
    "icon": "https://raw.githubusercontent.com/ionic-team/stencil/main/stencil-logo.png"
  },
  "keywords": [
    "stencil",
    "storybook",
    "storybook-addon"
  ]
}
